{
  "name": "rescript-bun-starter",
  "version": "2.0.0",
  "namespace": true,
  "sources": [
    {
      "dir": "src",
      "public": [
        "DinitGraph"
      ]
    },
    {
      "dir": "tests",
      "type": "dev"
    }
  ],
  "package-specs": {
    "module": "esmodule",
    "in-source": true
  },
  "suffix": ".mjs",
  "dependencies": [
    "rescript-bun"
  ],
  "compiler-flags": [
    "-open RescriptBun",
    "-open RescriptBun.Globals"
  ]
}