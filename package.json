{
	"name": "dinit-graph",
	"version": "0.1.0",
	"type": "module",
	"description": "A CLI built with Crust",
	"files": [
		"dist/dinit-graph",
		"dist/dinit-graph.cmd",
		"dist/*-bun-*"
	],
	"bin": {
		"dinit-graph": "dist/dinit-graph"
	},
	"scripts": {
		"dev": "bun run src/cli.ts",
		"build": "crust build --target linux-x64 --compile --minify --sourcemap ./src/cli.ts --outfile ./dist/dinit-graph",
		"package": "crust build --package --target linux-x64",
		"publish": "crust publish --target linux-x64 --stage-dir dist/npm",
		"start": "./dist/dinit-graph",
		"check:types": "tsc --noEmit"
	},
	"devDependencies": {
		"@crustjs/core": "^0.0.16",
		"@crustjs/crust": "^0.0.23",
		"@crustjs/plugins": "^0.0.21",
		"@types/bun": "^1.3.12",
		"typescript": "^6.0.2"
	},
	"dependencies": {
		"@types/node": "^25.6.0",
		"digraph-js": "^2.2.4"
	}
}
