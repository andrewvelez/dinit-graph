{
  "name": "dinit-graph",
  "version": "0.1.0",
  "description": "CLI tool to initialize a graph (ReScript v12 + Bun)",
  "type": "module",
  "main": "src/DinitGraph.mjs",
  "bin": {
    "dinit-graph": "dist/dinit-graph"
  },
  "scripts": {
    "build": "rescript build",
    "bundle": "bun build --target=bun ./src/DinitGraph.mjs --bundle --outfile ./dist/dinit-graph",
    "postbundle": "sed -i '1s;^;#!/usr/bin/env bun\\n;' ./dist/dinit-graph && chmod +x ./dist/dinit-graph",
    "release": "bun run build && bun run bundle",
    "watch": "rescript build -w"
  },
  "dependencies": {
    "rescript": "^12.2.0",
    "rescript-bun": "^2.1.0"
  },
  "devDependencies": {},
  "keywords": [
    "cli",
    "rescript",
    "bun",
    "graph"
  ],
  "license": "MIT"
}