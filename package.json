{
  "name": "dinit-graph",
  "version": "0.1.0",
  "description": "CLI tool to initialize a graph (ReScript v12 + Bun)",
  "type": "module",
  "main": "src/DinitGraph.mjs",
  "bin": {
    "dinit-graph": "dist/dinit-graph"
  },
  "scripts": {
    "build": "rescript build",
    "clean": "rescript clean",
    "bundle": "bun build --target=bun ./src/DinitGraph.res.mjs --outfile ./dist/dinit-graph && chmod +x ./dist/dinit-graph || true",
    "dev": "bun run build && bun run src/DinitGraph.res.mjs",
    "watch": "rescript build -w"
  },
  "devDependencies": {
    "rescript": "^12.2.0"
  },
  "keywords": [
    "cli",
    "rescript",
    "bun",
    "graph"
  ],
  "license": "MIT",
  "dependencies": {
    "rescript-bun": "2"
  }
}