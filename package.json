{
  "name": "rescript-bun-starter",
  "version": "1.0.0",
  "description": "A starter for using Bun with ReScript.",
  "scripts": {
    "test": "bun test tests/*.test.*",
    "build": "bun run rescript build",
    "dev:rescript": "bun:watch",
    "dev:server": "bun run --watch src/Main.js",
    "dev": "bun run rescript build && concurrently 'bun:dev:*'",
    "dev:test": "bun run test --watch",
    "watch": "rescript watch",
    "clean": "rescript clean",
    "format": "rescript format"
  },
  "keywords": [
    "rescript",
    "bun",
    "starter"
  ],
  "author": "Gabriel Nordeborn",
  "license": "MIT",
  "dependencies": {
    "rescript": "^12.2.0",
    "rescript-bun": "2"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "@types/bun": "latest"
  },
  "trustedDependencies": [
    "rescript"
  ]
}